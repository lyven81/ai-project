# Copy to .env and fill in. .env is git-ignored.

# Google Maps Places API key — used ONLY by cache/refresh_maps_cache.py on the schedule.
# Restrict the key to the Places API and to your service referrer for safety.
MAPS_API_KEY=

# Optional: cheap router model if you enable route_with_llm() (Gemini Flash / Claude Haiku).
# MODEL=gemini-2.0-flash
# GOOGLE_API_KEY=

# Cloud Run sets PORT automatically; default for local runs:
PORT=8080
