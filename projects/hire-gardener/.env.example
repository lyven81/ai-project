# Mode: "mock" for simulation, "real" for live WhatsApp
MODE=mock

# Ollama (local LLM - already installed on your machine)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3:latest

# WhatsApp Cloud API (only needed when MODE=real)
WHATSAPP_API_TOKEN=your_meta_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WEBHOOK_VERIFY_TOKEN=your_chosen_webhook_secret_here
