<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Owner Report — {{ property_name }} · {{ month_label }}</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600&family=Manrope:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
/* ---- WHITE-LABEL SKIN VARIABLES: this block is all that changes per agency ---- */
body[data-skin="kvh"]{--brand:#1E3A5F;--accent:#4A7FB5;--accent-soft:#EAF1F8;--agency:"Klang Valley Homes Realty";}
body[data-skin="harbour"]{--brand:#1F4D3F;--accent:#B0822A;--accent-soft:#F4EFE3;--agency:"Harbour & Co Realty";}
/* ------------------------------------------------------------------------------ */
:root{--ink:#22303F;--muted:#5B6B7C;--line:#D9E2EC;--green:#2F7D5C;--red:#A8453A}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Manrope',sans-serif;color:var(--ink);background:#EDF0F4;font-size:15px;line-height:1.6;padding:30px 16px}
.page{max-width:760px;margin:0 auto;background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 8px 30px rgba(30,58,95,.12)}
.head{background:var(--brand);color:#fff;padding:34px 38px}
.agency{font-size:12px;letter-spacing:.16em;text-transform:uppercase;font-weight:800;opacity:.85}
.agency::after{content:var(--agency)}
.head h1{font-family:'Fraunces',serif;font-weight:600;font-size:28px;margin-top:10px;line-height:1.2}
.head .sub{font-size:14px;opacity:.85;margin-top:6px}
.body{padding:30px 38px 36px}
h2{font-size:13px;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);font-weight:800;margin:26px 0 12px}
h2:first-child{margin-top:0}
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
@media(max-width:640px){.stats{grid-template-columns:repeat(2,1fr)}}
.stat{background:var(--accent-soft);border-radius:10px;padding:14px 16px;text-align:center}
.stat .v{font-family:'Fraunces',serif;font-size:30px;color:var(--brand);font-weight:600}
.stat .l{font-size:11.5px;color:var(--muted);font-weight:700;margin-top:2px}
p{margin-bottom:10px;max-width:68ch}
ul{list-style:none}
ul li{padding:8px 0 8px 26px;position:relative;border-bottom:1px solid var(--line);font-size:14.5px}
ul li:last-child{border-bottom:none}
ul li::before{content:"";position:absolute;left:4px;top:16px;width:8px;height:8px;border-radius:2px;background:var(--accent)}
.rec{background:var(--accent-soft);border-left:4px solid var(--accent);border-radius:8px;padding:16px 18px;margin-top:8px}
.rec strong{color:var(--brand)}
.foot{border-top:1px solid var(--line);padding:18px 38px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px;font-size:12.5px;color:var(--muted)}
.foot b{color:var(--brand)}
@media print{body{background:#fff;padding:0}.page{box-shadow:none;border-radius:0}}
</style>
</head>
<body data-skin="{{ skin }}">

<div class="page">
  <div class="head">
    <div class="agency"></div>
    <h1>Your property this month: {{ property_name }}</h1>
    <div class="sub">{{ subtitle }}</div>
  </div>
  <div class="body">

    <h2>The month at a glance</h2>
    <div class="stats">
      {% for s in stats %}<div class="stat"><div class="v">{{ s.v }}</div><div class="l">{{ s.l }}</div></div>
      {% endfor %}
    </div>

    <h2>What this means</h2>
    <p>{{ what_this_means }}</p>

    <h2>What we did for you in {{ month_short }}</h2>
    <ul>
      {% for item in did_items %}<li>{{ item }}</li>
      {% endfor %}
    </ul>

    <h2>Our recommendation</h2>
    <div class="rec">
      <strong>{{ rec_title }}</strong>
      <p style="margin:8px 0 0">{{ rec_body }}</p>
    </div>

    <h2>Next month</h2>
    <p>{{ next_month }}</p>
  </div>
  <div class="foot">
    <div><b>{{ agent_name }}</b> ({{ agent_pea }}) · your dedicated agent</div>
    <div>Prepared {{ prepared_date }} · Questions? WhatsApp us anytime</div>
  </div>
</div>
</body>
</html>
