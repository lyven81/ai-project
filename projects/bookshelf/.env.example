# Bookshelf — local development environment variables.
# Copy this to .env and fill in your values.

# Google Gemini API key (BYO).
# Get one free at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Optional: model override (default: gemini-2.5-flash)
BOOKSHELF_MODEL=gemini-2.5-flash

# Optional: dataset path override
# BOOKSHELF_DATASET_PATH=./dataset/dataset.xlsx

# For Cloud Run deployment only — set these in your shell, not here:
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_REGION=asia-southeast1
